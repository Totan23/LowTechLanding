# Consigue tu API key gratis (sin tarjeta, sin bloqueo regional) en:
#   https://openrouter.ai/keys
# La key empieza con "sk-or-v1-..."
OPENROUTER_API_KEY=pega-tu-api-key-aqui

# Opcional — modelo a usar. Por defecto: Gemini 2.0 Flash gratis vía OpenRouter.
# Alternativas gratuitas (sufijo :free):
#   google/gemini-2.0-flash-exp:free        (default — rápido, calidad alta)
#   meta-llama/llama-3.3-70b-instruct:free  (alternativa si Gemini cae)
#   qwen/qwen-2.5-72b-instruct:free         (muy bueno en español)
#   meta-llama/llama-3.2-3b-instruct:free   (ultrarrápido, calidad básica)
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Opcional — aparecen en el leaderboard público de OpenRouter si los defines
# SITE_URL=https://lowtechia.com
# SITE_NAME=Lowtech

# Opcional — puerto del proxy. Por defecto: 3001
# PORT=3001
